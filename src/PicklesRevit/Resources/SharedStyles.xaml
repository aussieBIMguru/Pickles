<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- SHARED VALUES -->
    <SolidColorBrush x:Key="Brush_Background"
                     Color="#363636"/>
    <SolidColorBrush x:Key="Brush_BackgroundMid"
                     Color="#757575"/>
    <SolidColorBrush x:Key="Brush_BackgroundInverse"
                     Color="White"/>
    <SolidColorBrush x:Key="Brush_BackgroundMouseOver"
                     Color="#0275a9"/>
    <SolidColorBrush x:Key="Brush_BackgroundMouseClick"
                     Color="#0696d7"/>
    <SolidColorBrush x:Key="Brush_BackgroundDisabled"
                     Color="#757575"/>
    <SolidColorBrush x:Key="Brush_Font"
                     Color="White"/>
    <SolidColorBrush x:Key="Brush_FontInverse"
                     Color="Black"/>
    <SolidColorBrush x:Key="Brush_FontDisabled"
                     Color="#363636"/>
    <SolidColorBrush x:Key="Brush_Border"
                     Color="#9b9b9b"/>
    <SolidColorBrush x:Key="Brush_BorderInverse"
                     Color="#363636"/>
    <SolidColorBrush x:Key="Brush_BorderDisabled"
                     Color="#363636"/>
    <FontFamily x:Key="Font_Default">Segoe UI</FontFamily>
    <Thickness x:Key="Thickness_Border">2</Thickness>
    <CornerRadius x:Key="CornerRadius_Default">5</CornerRadius>
    <Thickness x:Key="Margin_Small">2</Thickness>
    <Thickness x:Key="Margin_CheckBox">0,0,6,0</Thickness>

    <!-- WINDOW - IMPLICIT -->
    <Style TargetType="Window">
        <Setter Property="Foreground"
            Value="{StaticResource Brush_Font}" />
        <Setter Property="Background"
            Value="{StaticResource Brush_Background}" />
        <Setter Property="BorderThickness"
            Value="3" />
        <Setter Property="BorderBrush"
            Value="{StaticResource Brush_Border}" />
        <Setter Property="FontFamily"
            Value="{StaticResource Font_Default}" />
    </Style>

    <!-- BORDER - IMPLICIT -->
    <Style TargetType="Border">
        <Setter Property="BorderBrush"
            Value="{StaticResource Brush_Border}" />
        <Setter Property="BorderThickness"
            Value="{StaticResource Thickness_Border}"/>
        <Setter Property="CornerRadius"
            Value="{StaticResource CornerRadius_Default}"/>
    </Style>

    <!-- SCROLL BAR - IMPLICIT -->
    <Style  TargetType="ScrollBar">
        <Setter Property="Background"
            Value="{StaticResource Brush_BackgroundMid}" />
        <Setter Property="Foreground"
            Value="{StaticResource Brush_BorderInverse}" />
    </Style>

    <!-- TEXTBOX - IMPLICIT -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground"
            Value="{StaticResource Brush_Font}" />
        <Setter Property="Background"
            Value="{StaticResource Brush_Background}" />
        <Setter Property="BorderBrush"
            Value="{StaticResource Brush_Border}" />
        <Setter Property="BorderThickness"
            Value="{StaticResource Thickness_Border}" />
        <Setter Property="FontFamily"
            Value="{StaticResource Font_Default}" />
        <Setter Property="VerticalContentAlignment"
            Value="Center" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource CornerRadius_Default}">

                        <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="4,2"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled"
                             Value="False">
                            <Setter TargetName="border"
                                Property="Opacity"
                                Value="0.6"/>
                        </Trigger>

                        <!-- Focused -->
                        <Trigger Property="IsKeyboardFocused"
                             Value="True">
                            <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="{StaticResource Brush_BackgroundMouseClick}"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TEXTBLOCK - LABEL -->
    <Style x:Key="TextBlock_Label" TargetType="TextBlock">
        <Setter Property="Foreground"
            Value="{StaticResource Brush_Font}" />
        <Setter Property="FontFamily"
            Value="{StaticResource Font_Default}" />
    </Style>

    <!-- TEXTBLOCK - LABEL, BOLD -->
    <Style x:Key="TextBlock_LabelBold"
           TargetType="TextBlock"
           BasedOn="{StaticResource TextBlock_Label}">
        <Setter Property="FontWeight"
                Value="Bold" />
    </Style>

    <!-- BUTTON - IMPLICIT -->
    <Style TargetType="Button">
        <Setter Property="Foreground"
            Value="{StaticResource Brush_Font}" />
        <Setter Property="Background"
            Value="{StaticResource Brush_Background}" />
        <Setter Property="BorderBrush"
            Value="{StaticResource Brush_Border}" />
        <Setter Property="BorderThickness"
            Value="{StaticResource Thickness_Border}" />
        <Setter Property="FontFamily"
            Value="{StaticResource Font_Default}" />
        <Setter Property="FontWeight"
            Value="Bold" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource CornerRadius_Default}">

                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver"
                             Value="True">
                            <Setter TargetName="border"
                                Property="Background"
                                Value="{StaticResource Brush_BackgroundMouseOver}"/>
                        </Trigger>

                        <Trigger Property="IsPressed"
                             Value="True">
                            <Setter TargetName="border"
                                Property="Background"
                                Value="{StaticResource Brush_BackgroundMouseClick}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled"
                             Value="False">
                            <Setter TargetName="border"
                                Property="Background"
                                Value="{StaticResource Brush_BackgroundDisabled}"/>
                            <Setter TargetName="border"
                                Property="BorderBrush"
                                Value="{StaticResource Brush_BorderDisabled}"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LISTBOX - IMPLICIT -->
    <Style TargetType="ListBox">
        <Setter Property="Background"
            Value="{StaticResource Brush_Background}"/>
        <Setter Property="Foreground"
            Value="{StaticResource Brush_Font}"/>
        <Setter Property="BorderBrush"
            Value="{StaticResource Brush_Border}"/>
        <Setter Property="BorderThickness"
            Value="{StaticResource Thickness_Border}"/>
        <Setter Property="Padding"
            Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility"
            Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility"
            Value="Auto"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource CornerRadius_Default}">

                        <ScrollViewer Focusable="False"
                                  Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </ScrollViewer>

                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- LISTBOX ITEM - IMPLICIT -->
    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground"
                Value="{StaticResource Brush_Font}"/>
        <Setter Property="Background"
                Value="{StaticResource Brush_Background}"/>
        <Setter Property="Padding"
                Value="2" />
        <Setter Property="FontFamily"
                Value="{StaticResource Font_Default}"/>

        <!-- ALTERNATIVE STATES-->
        <Style.Triggers>

            <!-- MOUSE OVER -->
            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Background"
                        Value="{StaticResource Brush_BackgroundMouseOver}"/>
            </Trigger>

            <!-- SELECTED -->
            <Trigger Property="IsSelected"
                     Value="True">
                <Setter Property="Background"
                        Value="{StaticResource Brush_BackgroundMid}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource Brush_Font}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DATA TEMPLATE: SINGLE SELECT -->
    <DataTemplate x:Key="DataTemplate_SingleSelect">

        <TextBlock VerticalAlignment="Center"
                   Margin="2"
                   Text="{Binding ItemKey}"
                   Foreground="{StaticResource Brush_Font}"
                   FontFamily="{StaticResource Font_Default}"/>
    </DataTemplate>
    
    <!-- DATA TEMPLATE: MULTI SELECT (MUST LIVE IN ACTUAL CLASS) -->
    
    <!-- CHECKBOX: REFERENCE ONLY -->
    <Style TargetType="CheckBox" x:Key="CheckBox_MultiSelect_Reference">
        <!--<EventSetter Event="Click" Handler="CheckBox_Click" />-->
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Margin"
                Value="{StaticResource Margin_CheckBox}"/>
    </Style>

    <!-- DATA TEMPLATE - MULTISELECT -->
    <DataTemplate x:Key="DataTemplate_MultiSelect_Reference">
        <Grid Margin="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0"
              IsChecked="{Binding Checked, Mode=TwoWay}"
              Style="{StaticResource CheckBox_MultiSelect_Reference}"/>

            <TextBlock Grid.Column="1"
               VerticalAlignment="Center"
               Text="{Binding ItemKey}"
               Foreground="{StaticResource Brush_Font}"
               FontFamily="{StaticResource Font_Default}"/>
        </Grid>
    </DataTemplate>

    <!-- COMBOBOX BASE STYLE (APPLIES TO ALL) -->
    <Style TargetType="ComboBox">
        <Setter Property="Foreground"
                Value="{StaticResource Brush_Font}" />
        <Setter Property="Background"
                Value="{StaticResource Brush_Background}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource Brush_Border}" />
        <Setter Property="BorderThickness"
                Value="{StaticResource Thickness_Border}" />
        <Setter Property="Padding"
                Value="2" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="20" />
                        </Grid.ColumnDefinitions>

                        <!-- Closed surface -->
                        <Border x:Name="Border"
                                Grid.ColumnSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource CornerRadius_Default}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="ContentSite"
                                          Grid.Column="0"
                                          Margin="4,2"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          RecognizesAccessKey="True" />

                                <Path Grid.Column="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Fill="White"
                                      Data="M 0 0 L 4 4 L 8 0 Z" />
                            </Grid>
                        </Border>

                        <!-- Click behaviour -->
                        <ToggleButton x:Name="ToggleButton"
                              Grid.ColumnSpan="2"
                              Background="Transparent"
                              BorderThickness="0"
                              Focusable="False"
                              ClickMode="Press"
                              IsChecked="{Binding IsDropDownOpen,
                                                 RelativeSource={RelativeSource TemplatedParent},
                                                 Mode=TwoWay}"/>

                        <!-- Dropdown popup -->
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide"
                               Width="{Binding ActualWidth,
                                       RelativeSource={RelativeSource TemplatedParent}}">
                            <Border Background="{StaticResource Brush_Background}"
                                    BorderBrush="{StaticResource Brush_Border}"
                                    BorderThickness="1">
                                <ScrollViewer Margin="0"
                                      SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- COMBOBOX ITEM STYLE (APPLIES TO ALL) -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground"
                Value="{StaticResource Brush_Font}"/>
        <Setter Property="Background"
                Value="{StaticResource Brush_Background}"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FontWeight" Value="Regular"/>

        <Style.Triggers>
            <!-- Hover in dropdown -->
            <Trigger Property="IsHighlighted"
                     Value="True">
                <Setter Property="Background"
                        Value="{StaticResource Brush_BackgroundMouseOver}"/>
            </Trigger>

            <!-- Selected in dropdown -->
            <Trigger Property="IsSelected"
                     Value="True">
                <Setter Property="Background"
                        Value="{StaticResource Brush_BackgroundMouseClick}"/>
                <Setter Property="Foreground"
                        Value="{StaticResource Brush_Font}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- GROUPBOX STYLE (APPLIES TO ALL) -->
    <Style TargetType="GroupBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Border BorderBrush="{StaticResource Brush_Border}"
                                BorderThickness="{StaticResource Thickness_Border}"
                                CornerRadius="{StaticResource CornerRadius_Default}"
                                Padding="10">
                            <ContentPresenter />
                        </Border>

                        <!-- Header -->
                        <ContentPresenter ContentSource="Header"
                                      Margin="10,-20,0,0"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top"
                                      RecognizesAccessKey="True"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>