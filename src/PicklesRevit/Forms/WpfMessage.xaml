<!-- OVERALL WINDOW -->
<Window x:Class="Pickles.Forms.WpfMessage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PICKLES: MESSAGE"
        SizeToContent="Height"
        MinHeight="150"
        Width="400"
        MinWidth="300"
        MaxWidth="500"
        FontFamily="Segoe UI"
        Foreground="White"
        Background="#363636"
        WindowStartupLocation="CenterScreen"
        x:ClassModifier="internal">

    <!-- RESOURCES -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Pickles;component/Resources/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- MAIN GRID -->
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- FIXED TOOLTIP TEXT AREA -->
        <Border Grid.Row="0">
            <TextBlock x:Name="TooltipTextBlock"
                       Text="Default message."
                       Style="{StaticResource TextBlock_Label}"
                       Margin="6"
                       VerticalAlignment="Top"/>
        </Border>

        <!-- SHOW MORE BUTTON -->
        <Button x:Name="ShowMoreButton"
                Margin="0,12,0,0"
                Grid.Row="1"
                Content="Show more..."
                Padding="6,2"
                Visibility="Collapsed"
                Click="ShowMoreButton_Click"/>

        <!-- FIXED TOOLTIP TEXT AREA -->
        <Border x:Name="ShowMoreBorder"
                Grid.Row="2"
                Visibility="Collapsed"
                Margin="0,0,0,12">
            <TextBlock x:Name="ShowMoreTextBlock"
                       Text="Default message."
                       Style="{StaticResource TextBlock_Label}"
                       Margin="6"
                       VerticalAlignment="Top"/>
        </Border>

        <!-- SHOW MORE BUTTON -->
        <Button x:Name="LinkButton"
                Margin="0,12,0,0"
                Grid.Row="3"
                Content="Click to open link..."
                Padding="6,2"
                Visibility="Collapsed"
                Click="LinkButton_Click"/>

        <!-- BUTTONS ROW 1 -->
        <Grid x:Name="ButtonGrid" Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- OK BUTTON -->
            <Button x:Name="LeftButton"
                    Grid.Column="0"
                    Content="OK"
                    Margin="0,0,4,0"
                    Padding="6,2"
                    IsDefault="True"
                    Click="LeftButton_Click"/>

            <!-- CANCEL BUTTON -->
            <Button x:Name="RightButton"
                    Grid.Column="1"
                    Content="CANCEL"
                    Margin="4,0,0,0"
                    Padding="6,2"
                    IsCancel="True"
                    Click="RightButton_Click"/>
        </Grid>
    </Grid>
</Window>