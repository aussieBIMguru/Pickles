<!-- OVERALL WINDOW -->
<Window x:Class="Pickles.Forms.WpfEnterText"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Enter value"
        SizeToContent="Height"
        MinWidth="500"
        MinHeight="200"
        Width="500"
        FontFamily="Segoe UI"
        Foreground="White"
        Background="#363636"
        WindowStartupLocation="CenterScreen"
        x:ClassModifier="internal">

    <!-- RESOURCES -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Pickles;component/Resources/SharedStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- MAIN GRID -->
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- FIXED TOOLTIP TEXT AREA -->
        <Border Grid.Row="0"
                Margin="0,0,0,8">
            <TextBlock x:Name="TooltipTextBlock"
                       Text="Enter a value below."
                       Style="{StaticResource TextBlock_Label}"
                       Margin="6"/>
        </Border>

        <!-- TEXT ENTRY (SINGLE LINE) -->
        <TextBox Grid.Row="1"
                 x:Name="InputTextBox"
                 Margin="0,0,0,8"
                 PreviewTextInput="InputTextBox_PreviewTextInput"
                 PreviewKeyDown="InputTextBox_PreviewKeyDown" />

        <!-- BUTTONS ROW 1 -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- OK BUTTON -->
            <Button x:Name="OkButton"
                    Grid.Column="0"
                    Content="OK"
                    Margin="0,0,4,0"
                    Padding="6,2"
                    IsDefault="True"
                    Click="OkButton_Click"/>

            <!-- CANCEL BUTTON -->
            <Button Grid.Column="1"
                    Content="CANCEL"
                    Margin="4,0,0,0"
                    Padding="6,2"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </Grid>
    </Grid>
</Window>